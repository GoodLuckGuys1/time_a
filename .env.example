# Client ID с https://oauth.yandex.ru/ (приложение «Для доступа к API»)
TRACKER_OAUTH_CLIENT_ID=
TRACKER_OAUTH_CLIENT_SECRET=your_client_secret_here

# Права: чтение отчёта + редактирование списаний (перевыпустите токен после смены scope)
TRACKER_OAUTH_SCOPE=tracker:read tracker:write

# Для API-приложений Яндекса всегда verification_code (не localhost)
TRACKER_OAUTH_REDIRECT_URI=https://oauth.yandex.ru/verification_code

# Токен: вручную или через http://127.0.0.1:8000/oauth/start
TRACKER_OAUTH_TOKEN=

# ID организации: Администрирование → Организации → поле ID
TRACKER_ORG_ID=

# X-Org-ID для Яндекс 360, X-Cloud-Org-ID для Yandex Cloud
TRACKER_ORG_HEADER=X-Org-ID

# Доска из URL https://tracker.yandex.ru/agile/board/288
TRACKER_BOARD_ID=288
